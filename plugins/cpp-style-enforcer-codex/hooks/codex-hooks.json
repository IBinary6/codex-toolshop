{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/scripts/run-hook.cjs\" session_start",
            "timeout": 10,
            "statusMessage": "Preparing C++ style enforcement"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "apply_patch|Write|Edit|MultiEdit|NotebookEdit|mcp__.*(?:write|edit|create|replace|insert)",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/scripts/run-hook.cjs\" post_edit",
            "timeout": 10,
            "statusMessage": "Recording edited C++ files"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/scripts/run-hook.cjs\" stop_check",
            "timeout": 30,
            "statusMessage": "Finalizing C++ style"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/scripts/run-hook.cjs\" pre_commit",
            "timeout": 30,
            "statusMessage": "Checking staged C++ files"
          }
        ]
      }
    ]
  }
}
