{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/scripts/run-hook.cjs\" session_start",
            "timeout": 600,
            "statusMessage": "Building or updating CodeMap before use"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|apply_patch|Bash|mcp__.*(?:write|edit|create|replace|insert)",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/scripts/run-hook.cjs\" post_tool_use",
            "timeout": 600,
            "statusMessage": "Refreshing CodeMap after changes"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/scripts/run-hook.cjs\" pre_bash",
            "timeout": 5,
            "statusMessage": "Checking code search strategy"
          }
        ]
      },
      {
        "matcher": "mcp__(?:code_review_graph|code-review-graph|codegraph|graphify)__.*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/scripts/run-hook.cjs\" pre_graph_tool",
            "timeout": 600,
            "statusMessage": "Waiting for CodeMap refresh before graph access"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/scripts/run-hook.cjs\" user_prompt_submit",
            "timeout": 600
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/scripts/run-hook.cjs\" subagent_start",
            "timeout": 600
          }
        ]
      }
    ]
  }
}
